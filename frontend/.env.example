# Backend API URL (required for production)
VITE_API_BASE=https://your-api-url.com

# Supabase Auth (required for login)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Teller Connect (optional - for bank linking in checkout)
VITE_TELLER_APP_ID=
VITE_TELLER_ENVIRONMENT=sandbox
