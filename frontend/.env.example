# Backend API URL (required for production)
VITE_API_BASE=https://your-api-url.com

# Supabase Auth (required for login)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Customer checkout app URL (for payment links - QR, copy link, invoices)
# Set to your customer Amplify URL, e.g. https://main.d2ihokjg486p29.amplifyapp.com
VITE_CUSTOMER_BASE_URL=
